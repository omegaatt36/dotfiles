. "$HOME/.cargo/env"

# uv
export PATH="${HOME}/.local/bin:$PATH"

# zerobrew
export ZEROBREW_DIR=/Users/raiven_kao/.zerobrew
export ZEROBREW_BIN=/Users/raiven_kao/.local/bin
export PKG_CONFIG_PATH="/opt/zerobrew/prefix/lib/pkgconfig:${PKG_CONFIG_PATH:-}"
_zb_path_append() {
    local argpath="$1"
    case ":${PATH}:" in
        *:"$argpath":*) ;;
        *) export PATH="$argpath:$PATH" ;;
    esac;
}
_zb_path_append /opt/zerobrew/prefix/bin

# zerobrew
export PATH="/opt/zerobrew/bin:$PATH"
